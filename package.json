{
  "name": "rendercanvastovideo",
  "version": "0.2.3",
  "description": "RenderCanvasToVideo  — standalone app",
  "main": "main.js",
  "author": "Javier Jara",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "NODE_ENV=development electron .",
    "mcp": "node mcp-server.js",
    "test": "node test-pipeline.js",
    "test:node": "node --test tests/*.test.js",
    "test:python": "python3 -m unittest discover tests -v",
    "test:all": "npm run test:node && npm run test:python",
    "install:ffmpeg": "node scripts/install-ffmpeg.js",
    "predist": "node scripts/install-chrome.js && node scripts/install-ffmpeg.js",
    "predist:win": "node scripts/install-chrome.js win64 && node scripts/install-ffmpeg.js win64",
    "predist:mac": "node scripts/install-chrome.js mac-arm64 && node scripts/install-ffmpeg.js mac-arm64",
    "predist:linux": "node scripts/install-chrome.js linux64 && node scripts/install-ffmpeg.js linux64",
    "dist:mac": "npm run predist:mac && electron-builder --mac",
    "dist:win": "npm run predist:win && electron-builder --win",
    "dist:linux": "npm run predist:linux && electron-builder --linux",
    "postinstall": "puppeteer browsers install chrome",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev:vite": "vite",
    "build:vite": "tsc && vite build",
    "preview:vite": "vite preview"
  },
  "bin": {
    "rendercanvastovideo-mcp": "mcp-server.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "express": "^5.2.1",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "multer": "^2.1.1",
    "puppeteer": "^24.43.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.javierjarart.rendercanvastovideo",
    "productName": "RenderCanvasToVideo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      ".puppeteerrc.cjs",
      "public/**/*",
      "proyectos/**/*",
      "node_modules/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "extraResources": [
      {
        "from": "public",
        "to": "../public"
      },
      {
        "from": "proyectos",
        "to": "../proyectos"
      },
      {
        "from": "bin",
        "to": "../bin"
      },
      {
        "from": ".cache/puppeteer",
        "to": "../.cache/puppeteer"
      }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.video"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico",
      "signtoolOptions": {
        "publisherName": "Javier Jara"
      }
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
