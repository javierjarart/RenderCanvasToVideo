{
  "name": "rendercanvastovideo",
  "displayName": "Render Canvas to Video",
  "description": "Render HTML canvas animations to MP4 video files from VS Code",
  "version": "1.0.0",
  "publisher": "javierjarart",
  "license": "ISC",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "rendercanvastovideo.openPanel",
        "title": "Render Canvas to Video: Open Panel"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "rendercanvastovideo.openPanel",
          "group": "2_workspace"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
