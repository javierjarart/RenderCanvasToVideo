{
  "productName": "RenderCanvasToVideo",
  "version": "0.4.0",
  "identifier": "com.javierjarart.rendercanvastovideo",
  "build": {
    "frontendDist": "../public",
    "removeUnusedCommands": false
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "RenderCanvasToVideo",
        "width": 740,
        "height": 380,
        "minWidth": 600,
        "minHeight": 380,
        "resizable": true
      },
      {
        "label": "render-capture",
        "visible": false,
        "width": 1,
        "height": 1,
        "resizable": false,
        "decorations": false,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
