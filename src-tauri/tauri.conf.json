{
  "productName": "RenderCanvasToVideo",
  "version": "0.3.0",
  "identifier": "com.javierjarart.rendercanvastovideo",
  "build": {
    "frontendDist": "../public",
    "removeUnusedCommands": false
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RenderCanvasToVideo",
        "width": 740,
        "height": 380,
        "minWidth": 600,
        "minHeight": 380,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "binaries/*": "./"
    },
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
